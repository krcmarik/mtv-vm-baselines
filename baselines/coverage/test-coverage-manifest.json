{
  "manifest_version": "1.0",
  "generated_from": "mtv-api-tests",
  "tests": {
    "test_cold_migration_comprehensive": {
      "test_class": "TestColdMigrationComprehensive",
      "test_file": "tests/cold/test_cold_migration_comprehensive.py",
      "vms": [
        "mtv-win2019-3disks"
      ],
      "markers": [
        "openshift",
        "openstack",
        "rhv",
        "tier0",
        "vsphere"
      ],
      "vm_power_state": "on",
      "features": {
        "warm_migration": false,
        "preserve_static_ips": true,
        "target_power_state": "on",
        "pvc_name_template": "{{.VmName}}-disk-{{.DiskIndex}}",
        "pvc_name_template_use_generate_name": false,
        "target_labels": {
          "mtv-comprehensive-label": null,
          "test-type": "comprehensive"
        },
        "target_affinity": {
          "podAffinity": {
            "preferredDuringSchedulingIgnoredDuringExecution": [
              {
                "podAffinityTerm": {
                  "labelSelector": {
                    "matchLabels": {
                      "app": "test"
                    }
                  },
                  "topologyKey": "kubernetes.io/hostname"
                },
                "weight": 50
              }
            ]
          }
        },
        "target_node_selector": {
          "mtv-comprehensive-node": null
        },
        "vm_target_namespace": "mtv-vms-cold-comprehensive-<dynamic>",
        "multus_namespace": "default",
        "guest_agent_timeout": 600
      },
      "expected_checks": [
        "affinity",
        "cpu",
        "guest_agent",
        "labels",
        "memory",
        "network",
        "nic_name",
        "node_selector",
        "power_state",
        "pvc_names",
        "rhv_power_off_event",
        "serial",
        "ssh_connectivity",
        "ssl_config",
        "static_ip",
        "storage"
      ]
    },
